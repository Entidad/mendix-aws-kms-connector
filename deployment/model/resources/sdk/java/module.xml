<?xml version="1.0" encoding="utf-8"?>
<module xmlns="http://www.mendix.com/module/1.0/">
    <name>AWS_KMS_Connector</name>
    <description>AWS Key Management Service (KMS) Connector Module for Mendix</description>
    <version>1.0.0</version>
    <type>JavaLibrary</type>
    <company>Mendix</company>
    <license>Apache License 2.0</license>

    <!-- Java Actions -->
    <actions>
        <!-- Create Key Action -->
        <action name="CreateKey">
            <description>Creates a new customer-managed KMS key</description>
            <parameters>
                <parameter name="accessKey" type="String" required="true">
                    <description>AWS Access Key ID</description>
                </parameter>
                <parameter name="secretKey" type="String" required="true">
                    <description>AWS Secret Access Key</description>
                </parameter>
                <parameter name="region" type="String" required="true">
                    <description>AWS Region (e.g., us-east-1)</description>
                </parameter>
                <parameter name="description" type="String" required="true">
                    <description>Key description</description>
                </parameter>
                <parameter name="keyUsage" type="String" required="true">
                    <description>Key usage (SIGN_VERIFY or ENCRYPT_DECRYPT)</description>
                </parameter>
            </parameters>
            <return type="Object">
                <description>CreateKeyResponse object with keyId, keyArn, success, and errorMessage</description>
            </return>
        </action>

        <!-- Encrypt Action -->
        <action name="Encrypt">
            <description>Encrypts plaintext using a KMS key</description>
            <parameters>
                <parameter name="accessKey" type="String" required="true">
                    <description>AWS Access Key ID</description>
                </parameter>
                <parameter name="secretKey" type="String" required="true">
                    <description>AWS Secret Access Key</description>
                </parameter>
                <parameter name="region" type="String" required="true">
                    <description>AWS Region (e.g., us-east-1)</description>
                </parameter>
                <parameter name="keyId" type="String" required="true">
                    <description>KMS Key ID or ARN</description>
                </parameter>
                <parameter name="plaintext" type="String" required="true">
                    <description>Plaintext data to encrypt</description>
                </parameter>
            </parameters>
            <return type="Object">
                <description>EncryptResponse object with ciphertextBlob, keyId, success, and
                    errorMessage</description>
            </return>
        </action>

        <!-- Decrypt Action -->
        <action name="Decrypt">
            <description>Decrypts ciphertext encrypted with KMS</description>
            <parameters>
                <parameter name="accessKey" type="String" required="true">
                    <description>AWS Access Key ID</description>
                </parameter>
                <parameter name="secretKey" type="String" required="true">
                    <description>AWS Secret Access Key</description>
                </parameter>
                <parameter name="region" type="String" required="true">
                    <description>AWS Region (e.g., us-east-1)</description>
                </parameter>
                <parameter name="ciphertextBlob" type="String" required="true">
                    <description>Base64-encoded encrypted data</description>
                </parameter>
            </parameters>
            <return type="Object">
                <description>DecryptResponse object with plaintext, keyId, success, and errorMessage</description>
            </return>
        </action>

        <!-- Generate Data Key Action -->
        <action name="GenerateDataKey">
            <description>Generates a data key for envelope encryption</description>
            <parameters>
                <parameter name="accessKey" type="String" required="true">
                    <description>AWS Access Key ID</description>
                </parameter>
                <parameter name="secretKey" type="String" required="true">
                    <description>AWS Secret Access Key</description>
                </parameter>
                <parameter name="region" type="String" required="true">
                    <description>AWS Region (e.g., us-east-1)</description>
                </parameter>
                <parameter name="keyId" type="String" required="true">
                    <description>KMS Key ID or ARN</description>
                </parameter>
                <parameter name="keySpec" type="String" required="true">
                    <description>Data key spec (AES_128, AES_256)</description>
                </parameter>
            </parameters>
            <return type="Object">
                <description>GenerateDataKeyResponse object with plaintext, encryptedDataKey, keyId,
                    success, and errorMessage</description>
            </return>
        </action>
    </actions>

    <!-- Microflow Constants -->
    <constants>
        <constant name="DefaultRegion" type="String" value="us-east-1">
            <description>Default AWS region</description>
        </constant>
        <constant name="EncryptDecryptKeyUsage" type="String" value="ENCRYPT_DECRYPT">
            <description>Key usage for encryption/decryption</description>
        </constant>
        <constant name="SignVerifyKeyUsage" type="String" value="SIGN_VERIFY">
            <description>Key usage for signing and verification</description>
        </constant>
    </constants>

    <!-- Documentations -->
    <documentation>
        <title>AWS KMS Connector Module</title>
        <content>
            <section>
                <title>Overview</title>
                <text>This module provides integration with AWS Key Management Service (KMS) for
                    secure key management and cryptographic operations in Mendix applications.</text>
            </section>
            <section>
                <title>Features</title>
                <list>
                    <item>Create customer-managed KMS keys</item>
                    <item>Encrypt and decrypt data using KMS</item>
                    <item>Generate data keys for envelope encryption</item>
                    <item>AWS Access Key authentication</item>
                </list>
            </section>
            <section>
                <title>Installation</title>
                <text>
                    1. Import the AWS KMS Connector module into your Mendix project
                    2. Add the required Java actions to your microflows
                    3. Configure AWS credentials in your Mendix constants or as module parameters
                    4. Call the actions from your microflows
                </text>
            </section>
            <section>
                <title>Usage Example</title>
                <text>
                    To encrypt data:
                    1. Drag the 'Encrypt' Java action into your microflow
                    2. Set parameters: accessKey, secretKey, region, keyId, plaintext
                    3. The response will contain ciphertextBlob (base64 encoded)

                    To decrypt:
                    1. Drag the 'Decrypt' Java action into your microflow
                    2. Set parameters: accessKey, secretKey, region, ciphertextBlob
                    3. The response will contain the decrypted plaintext
                </text>
            </section>
        </content>
    </documentation>
</module>